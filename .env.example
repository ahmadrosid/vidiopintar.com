# Local dev: ./data/vidiopintar.db
# Docker: use /data/vidiopintar.db (or omit — the app defaults to /data in production)
SQLITE_DATABASE_PATH=./data/vidiopintar.db

# Optional. Stabilizes server action IDs across deploys. Falls back to CLERK_SECRET_KEY.
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

DEEPSEEK_API_KEY=
TRANSCRIPT_API_KEY=
YOUTUBE_API_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

API_BASE_URL=https://api.ahmadrosid.com
API_X_HEADER_API_KEY=

ADMIN_MASTER_EMAIL=
PAYMENT_CONTACT_CONFIG=
